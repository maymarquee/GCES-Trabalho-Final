# Copy this file to .env and edit as needed.
# .env is NOT tracked by Git (see .gitignore).

# Port published on the host for the app. The container always listens on 55555 internally.
HOST_PORT=55555

# Port published on the host for Postgres (useful for psql/pgAdmin access in dev).
DB_HOST_PORT=5432

# Postgres credentials — used by both the db service and the app service.
PGUSER=mkjs
PGPASSWORD=mkjs
PGDATABASE=mkjs
